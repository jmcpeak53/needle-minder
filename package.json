{
  "name": "needle-minder",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "npx expo start --dev-client --host lan",
    "start": "expo start",
    "catalog:audit": "tsx scripts/catalogFamilyAuditServer.ts",
    "catalog:audit:apply": "tsx scripts/applyCatalogFamilyAudit.ts",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:preview": "eas build --profile preview-apk --platform android",
    "build:testflight": "eas build --profile testflight --platform ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "validate:catalog": "tsx scripts/validateCatalog.ts"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "drizzle-orm": "^0.44.0",
    "expo": "~55.0.23",
    "expo-camera": "~55.0.18",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.32",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.19",
    "expo-font": "~55.0.7",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-sharing": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.28.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "~29.7.0",
    "babel-preset-expo": "~55.0.21",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.17",
    "react-test-renderer": "19.2.0",
    "tsx": "^4.20.0",
    "typescript": "~5.9.0"
  }
