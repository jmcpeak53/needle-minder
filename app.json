{
  "expo": {
    "name": "Needle Minder",
    "slug": "needle-minder",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "needleminder",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.needleminder.app"
    },
    "android": {
      "package": "com.needleminder.app",
      "adaptiveIcon": {
        "backgroundColor": "#f8f1e7"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Needle Minder to scan a thread label."
        }
      ],
      "expo-font",
      "expo-sharing",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ad406d51-e490-42e0-921e-d87f43cbe3af"
      }
    },
    "owner": "jmcpeak53"
  }
}
